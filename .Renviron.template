# Environment Variables Template
# Copy this file to .Renviron and fill in your actual API keys
# NEVER commit .Renviron to version control

# OpenAI API Key for ellmer
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic API Key (if using Claude)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Uncomment to enable plot refinement review
# VASPER_PLOT_REFINEMENT_ENABLED=true
# VASPER_PLOT_REFINEMENT_MODEL=gpt-4o-mini

# USDA NASS API Key (for yield benchmarks)
# USDA_NASS_API_KEY=your_usda_api_key_here

# Davis WeatherLink API credentials
DAVIS_API_KEY=your_davis_api_key_here
DAVIS_API_SECRET=your_davis_api_secret_here
